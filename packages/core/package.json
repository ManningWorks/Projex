{
  "name": "@manningworks/projex",
  "version": "1.1.3",
  "description": "Show Everything You Ship",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "projex": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./themes/theme-minimal.css": "./dist/themes/theme-minimal.css",
    "./themes/theme-dark.css": "./dist/themes/theme-dark.css",
    "./themes/theme-gradient.css": "./dist/themes/theme-gradient.css"
  },
  "scripts": {
    "build": "tsc && node copy-components.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --max-warnings 0",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "test:components": "vitest run --config vitest.config.ts src/components",
    "benchmark": "vitest bench --config vitest.config.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ManningWorks/Projex.git"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.6",
    "@types/react-dom": "^19.0.6",
    "@typescript-eslint/eslint-plugin": "^8.19.0",
    "@typescript-eslint/parser": "^8.19.0",
    "@vitest/coverage-v8": "2.1.8",
    "eslint": "^9.17.0",
    "jsdom": "^26.0.0",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  },
  "dependencies": {
    "@inquirer/prompts": "^6.0.1",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "fuse.js": "^7.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.24.1"
  }
}
