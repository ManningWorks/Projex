{
  "name": "projex",
  "version": "1.0.1",
  "description": "Show Everything You Ship",
  "private": true,
  "scripts": {
    "build": "pnpm --filter './packages/**' build",
    "typecheck": "pnpm --filter './packages/**' typecheck",
    "lint": "pnpm --filter './packages/**' lint",
    "test": "pnpm --filter './packages/**' test",
    "benchmark": "pnpm --filter @manningworks/projex benchmark"
  },
  "devDependencies": {
    "tsx": "^4.21.0",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@9.15.0",
  "workspaces": [
    "packages/*",
    "apps/*"
  ]
}
